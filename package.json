{
	"name": "cent-monorepo",
	"private": true,
	"version": "2.0",
	"type": "module",
	"packageManager": "pnpm@10.15.1",
	"scripts": {
		"dev": "pnpm --filter cent dev",
		"build": "pnpm --filter cent build",
		"preview": "pnpm --filter cent preview",
		"analyze": "pnpm --filter cent analyze",
		"dev:chaty": "pnpm --filter @glink25/chaty dev",
		"dev:zen": "pnpm --filter @glink25/zen dev",
		"build:chaty": "pnpm --filter @glink25/chaty build",
		"build:zen": "pnpm --filter @glink25/zen build",
		"lint": "pnpm -r lint",
		"pre-commit": "pnpm -r lint",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.2",
		"@commitlint/cli": "^20.2.0",
		"@commitlint/config-conventional": "^20.2.0",
		"husky": "^9.1.7"
	}
}
